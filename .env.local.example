# Copy this file to ".env.local" and fill in your values for local development.
# On Vercel, set these in Project Settings -> Environment Variables instead.

# Your free token from https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=your_token_here

# A long random string. Protects the /api/cron/refresh endpoint.
# Vercel Cron automatically sends this. Generate one with: openssl rand -hex 32
CRON_SECRET=replace_with_a_long_random_string
